          "purpose": "Project overview and notebook-based RAG pipeline description",
          "key_symbols": []
        },
        {
          "path": "requirements.txt",
          "purpose": "Python dependencies list",
          "key_symbols": []
        },
        {
          "path": "Embedding.ipynb",
          "purpose": "Notebook for embedding workflow",
          "key_symbols": []
        },
        {
          "path": "Scraping and Chunking.ipynb",
          "purpose": "Notebook for scraping and chunking UTD content",
          "key_symbols": []
        },
        {
          "path": "unique_links.xls",
          "purpose": "Spreadsheet of collected links",
          "key_symbols": []
        }
      ]
